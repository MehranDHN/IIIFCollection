    rdfs:comment "Associates a camera man to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "camera man of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleCameraMan .        

mdhn:hasParticipantInRoleInvolver a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to involvers";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRoleInvolver" ;
    rdfs:range mdhn:AgentialInfo . 

mdhn:involvesIn a owl:ObjectProperty ;
    rdfs:comment "Associates an involver to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "involves in" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleInvolver .      

mdhn:hasParticipantInRoleSignatory a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRoleSignatory" ;
    rdfs:range mdhn:AgentialInfo . 

mdhn:signatoryOf a owl:ObjectProperty ;
    rdfs:comment "Associates a signatory to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "signatory of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleSignatory .     

mdhn:hasParticipantInRoleReferredTo a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRoleReferredTo" ;
    rdfs:range mdhn:AgentialInfo .

mdhn:refersTo a owl:ObjectProperty ;
    rdfs:comment "Associates a digital resource to its associated subjects" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "refers to" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleReferredTo . 

mdhn:hasParticipantInRoleDrawer a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRoleDrawer" ;
    rdfs:range mdhn:AgentialInfo .  

mdhn:drawsPlan a owl:ObjectProperty ;
    rdfs:comment "Associates a drawer to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "draws plan" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleDrawer .           

mdhn:hasParticipantInRolePainter a owl:ObjectProperty ;
