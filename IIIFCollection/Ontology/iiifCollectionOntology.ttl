@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix so: <https://schema.org/> .
@prefix stardog: <tag:stardog:api:> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://api.stardog.com/> .
@prefix aat: <https://vocab.getty.edu/aat/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix mdhn: <http://example.com/mdhn/> .
@prefix wd: <https://www.wikidata.org/wiki/> .
@prefix tgm: <http://id.loc.gov/vovabulary/graphicMaterials/> .
@prefix tgn: <http://vocab.getty.edu/tgn/> .
@prefix fhkb: <http://www.example.com/genealogy.owl#> .
@prefix lcsh: <https://id.loc.gov/authorities/subjects/> .


mdhn:IIIFDexirOntology a owl:Ontology ;
    rdfs:label "IIIFDexir Project Ontology"@en ;
    rdfs:comment "An ontology for IIIFDexir project and its resources based on a provided JSON model."@en .

mdhn:ResourceCollection a owl:Class ;
    rdfs:comment "A collection of IIIF resources that contain manifests and nested collections." ;
    rdfs:label "Resource Collection" .

mdhn:DigitalResource a owl:Class ;
    rdfs:comment "A IIIF manifest representing a digital resource such as a book, photograph, or video." ;
    rdfs:label "Digital Resource" .

mdhn:ResourceCanvas a owl:Class ;
    rdfs:comment "Canvas of a IIIF manifest representing a page or image within a digital resource." ;
    rdfs:label "Resource Canvas" .

mdhn:CanvasContentElemet a owl:Class ;
    rdfs:comment "various content element that can appear in a canvas" ;
    rdfs:label "CanvasLinguisticObject" . 

mdhn:LinguisticElement a owl:Class ;
    rdfs:comment "Linguistic Object in each canvas" ;
    rdfs:label "LinguisticElement";
    rdfs:subClassOf  mdhn:CanvasContentElemet. 

mdhn:PhotographElement a owl:Class ;
    rdfs:comment "Photograph or portrailt drawing Object in each canvas" ;
    rdfs:label "PhotographElement";
    rdfs:subClassOf  mdhn:CanvasContentElemet.         

mdhn:Cropped_Details a owl:Class ;
    rdfs:comment "Cropped Details from an image" ;
    rdfs:label "Cropped_Details";
    rdfs:subClassOf  mdhn:CanvasContentElemet.         

mdhn:CroppedFigure a owl:Class ;
    rdfs:comment "Cropped Figurefrom an image" ;
    rdfs:label "CroppedFigure";
    rdfs:subClassOf  mdhn:Cropped_Details.  

mdhn:CroppedPattern a owl:Class ;
    rdfs:comment "Cropped Pattern from an image" ;
    rdfs:label "CroppedPattern";
    rdfs:subClassOf  mdhn:Cropped_Details.           

mdhn:Creator a owl:Class ;
    rdfs:comment "An entity responsible for creating the digital resource." ;
    rdfs:label "Creator" .       

mdhn:AATTerm a owl:Class ;
    rdfs:comment "Root Class for all AAT inherited concepts" ;
    rdfs:label "AATTerm";
    rdfs:subClassOf  mdhn:SubjectSource  .

mdhn:AATSubject a owl:Class ;
    rdfs:comment "Classes choosed as AAT subset for Subjects and it is used to associate AATs as Topical headings to the photographs" ;
    rdfs:label "AATSubject" ;
    rdfs:subClassOf mdhn:AATTerm .

mdhn:ScriptStyleType a owl:Class ;
    rdfs:comment "Classes choosed as a small AAT subset and it is used to determine the script style of all kinds of calligraphy resources." ;
    rdfs:label "Script Style Type" ;
    rdfs:subClassOf mdhn:AATTerm .

mdhn:ResourceType a owl:Class ;
    rdfs:comment "Classes choosed as a AAT subset and it is used as First Level Classification of all resources." ;
    rdfs:label "Resource Type" ;
    rdfs:subClassOf mdhn:AATTerm .

mdhn:DocumentGenre a owl:Class ;
    rdfs:comment "Classes choosed as a subset and it is used as Second Level classification of document resources." ;
    rdfs:label "Document Genre" ;
    rdfs:subClassOf mdhn:AATTerm .

mdhn:DepartedCollection a owl:Class ;
    rdfs:comment "The class for integrating departed folios as logical collection into a single virtual collection" ;
    rdfs:label "Departed Collection" .



mdhn:Iconography a owl:Class ;
    rdfs:comment "Root class of Iconography" ;
    rdfs:label "Iconography" .  

mdhn:BattleSignAndEquipment a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to War and Battle." ;
    rdfs:label "BattleSignAndEquipment" . 

mdhn:ArchitecturalConceptOrElement a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to Architecture including concepts, material and elements" ;
    rdfs:label "ArchitecturalConceptOrElement" . 

mdhn:Art a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to Art" ;
    rdfs:label "Art" .     

mdhn:Manuscript_Processing a owl:Class ;
    rdfs:subClassOf mdhn:Art ;
    rdfs:comment "SubClass of Iconography related to Manuscript processing" ;
    rdfs:label "Manuscript Processing" .

   
mdhn:Entertainment_Events a owl:Class ;
    rdfs:subClassOf mdhn:Art ;
    rdfs:comment "SubClass of Iconography related to Entertainment" ;
    rdfs:label "Entertainment_Events" .        

mdhn:GameAndHobby a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to Games and Hobbies" ;
    rdfs:label "GameAndHobby" . 

mdhn:MusicalInstrument a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to Music" ;
    rdfs:label "MusicalInstrument" . 

mdhn:ClothingAndDress a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to CLothing and dress" ;
    rdfs:label "ClothingAndDress" . 

mdhn:NaturalElement a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to Natural Phenumena and Elements" ;
    rdfs:label "NaturalElement" . 

mdhn:Events a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to cover Events" ;
    rdfs:label "NaturalElement" .     
mdhn:HistoricalEvent a owl:Class ;
    rdfs:subClassOf mdhn:Events ;
    rdfs:comment "SubClass of Iconography related to Historical Events" ;
    rdfs:label "HistoricalEvent" .     

mdhn:MythicalEvent a owl:Class ;
    rdfs:subClassOf mdhn:Events ;
    rdfs:comment "SubClass of Iconography related to Mythical Events" ;
    rdfs:label "MythicalEvent" .          
mdhn:Animals a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to Animals" ;
    rdfs:label "Animals" . 

mdhn:MythicalAnimalsOrMonsters a owl:Class ;
    rdfs:subClassOf mdhn:Animals ;
    rdfs:comment "SubClass of Animals" ;
    rdfs:label "MythicalAnimalsOrMonsters" .     

mdhn:Tableware a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography for Tableware and eating/drinking" ;
    rdfs:label "Tableware" .     

mdhn:TravelsAndTransportation a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to Travels/Ridding and Transportation" ;
    rdfs:label "TravelsAndTransportation" . 

mdhn:JobsAndCreativity a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to Jobs and Creativity" ;
    rdfs:label "JobsAndCreativity" . 

mdhn:MythicalHumanPersona a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related Mythical Humans" ;
    rdfs:label "MythicalHumanPersona" .  

mdhn:MonarchOrHistoricalCeremony a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related to Monarch Ceremony" ;
    rdfs:label "MonarchOrHistoricalCeremony" . 

mdhn:ObjectsAndTools a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related Objects and Tools" ;
    rdfs:label "ObjectAndTools" .  

mdhn:SubjectiveConcepts a owl:Class ;
    rdfs:subClassOf mdhn:Iconography ;
    rdfs:comment "SubClass of Iconography related Concepts" ;
    rdfs:label "SubjectiveConcepts" . 

mdhn:Emotion a owl:Class ;
    rdfs:subClassOf mdhn:SubjectiveConcepts ;
    rdfs:comment "SubClass of SubjectiveConcepts" ;
    rdfs:label "Emotion" .                                


mdhn:NarrativeEpisode a owl:Class ;
    rdfs:comment "A narrative episode depicted in a resource, such as a scene from a story or historical event." ;
    rdfs:label "Narrative Episode" ;
    rdfs:subClassOf mdhn:Iconography .      
        

mdhn:CanvasType a owl:Class ;
    rdfs:comment "The type of canvas used within a IIIF manifest to represent a resource page or image." ;
    rdfs:label "Canvas Type" .

mdhn:LCTGMSubject a owl:Class ;
    rdfs:comment "Classes to associate Theasures Of Graphical Material subjects to the photographs" ;
    rdfs:label "LCTGMSubject" ;
    rdfs:subClassOf mdhn:SubjectSource .

mdhn:LCSHSubject a owl:Class ;
    rdfs:comment "Classes to associate LC Subject Headings to the photographs" ;
    rdfs:label "LCSHSubject" ;
    rdfs:subClassOf mdhn:SubjectSource .

mdhn:GettyTGN a owl:Class ;
    rdfs:comment "Getty TGN Class for Geographic Places" ;
    rdfs:label "GettyTGN" .

mdhn:FeaturedSitesOrBuilding a owl:Class ;
    rdfs:comment "Featured buildings are special type of spatial object whithin Cities/Provinance/Villages" ;
    rdfs:label "FeaturedSitesOrBuilding" ;
    rdfs:subClassOf mdhn:GettyTGN .    

mdhn:AgentialInfo a owl:Class ;
    rdfs:comment "Agential info based on FHKB and references to wikidata when possible" ;
    rdfs:label "AgentialInfo" ;
    rdfs:subClassOf fhkb:Person .

mdhn:GLAMSource a owl:Class;
    rdfs:comment "GLAM sources sre the publishers or holders of the digital resources and they are associated to the resources through the publisher property." ;
    rdfs:label "GLAMSource" .    



mdhn:TemporalInfo a owl:Class ;
    rdfs:comment "First try to support temporal entity type" ;
    rdfs:label "TemporalInfo" .

mdhn:ParticipantRole a owl:Class ;
    rdfs:comment "Roles Participated by Involver in Digital Resource" ;
    rdfs:label "Participant Role" .  

mdhn:canvasOf a owl:ObjectProperty ;
    rdfs:comment "Associated narrative episode to which the iconographic entity belongs."@en ;
    rdfs:domain mdhn:ResourceCanvas ;
    rdfs:label "canvas Of"@en , "مربوط به"@fa ;
    rdfs:range mdhn:DigitalResource .  

mdhn:hasCanvas a owl:ObjectProperty ; 
    rdfs:domain mdhn:DigitalResource ;
    rdfs:range  mdhn:ResourceCanvas ;
    rdfs:label  "Digital resource has canvas"@en ;
    owl:inverseOf mdhn:canvasOf .  

mdhn:hasLinguisticElement a owl:ObjectProperty ; 
    rdfs:domain mdhn:ResourceCanvas;
    rdfs:range  mdhn:LinguisticElement ;
    rdfs:label  "hasLinguisticElement"@en ;
    rdfs:comment "Canvas has Linguistic Element" . 

mdhn:loBelongsToCanvas a owl:ObjectProperty ; 
    rdfs:domain mdhn:LinguisticElement ;
    rdfs:range  mdhn:ResourceCanvas ;
    rdfs:label  "loBelongsToCanvas"@en ;
    owl:inverseOf mdhn:hasLinguisticElement .  

mdhn:hasCroppedDetails a owl:ObjectProperty ; 
    rdfs:domain mdhn:ResourceCanvas;
    rdfs:range  mdhn:Cropped_Details ;
    rdfs:label  "hasCroppedDetails"@en ;
    rdfs:comment "Canvas has Cropped image Element" . 

mdhn:detailBelongsToCanvas a owl:ObjectProperty ; 
    rdfs:domain mdhn:Cropped_Details ;
    rdfs:range  mdhn:ResourceCanvas ;
    rdfs:label  "detailBelongsToCanvas"@en ;
    owl:inverseOf mdhn:hasCroppedFigure . 




mdhn:elementHasSubject a owl:ObjectProperty ;
    rdfs:domain mdhn:CanvasContentElemet ;
    rdfs:label "elementHasSubject"@en ;
    rdfs:range mdhn:SubjectSource .    

mdhn:elementDepicts a owl:ObjectProperty ; 
    rdfs:domain mdhn:CanvasContentElemet;
    rdfs:range  mdhn:Iconography ;
    rdfs:label  "element Depicts"@en .                      

mdhn:isPartOf a owl:ObjectProperty ;
    rdfs:comment "Associated narrative episode to which the iconographic entity belongs."@en ;
    rdfs:domain mdhn:NarrativeEpisode ;
    rdfs:label "is part of"@en , "بخشی از"@fa ;
    rdfs:range mdhn:NarrativeEpisode . 

mdhn:depicts a owl:ObjectProperty ;
    rdfs:comment "Links a DigitalResource to the entities it depicts." ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf ( mdhn:ResourceCanvas mdhn:DigitalResource )
    ] ;    
    rdfs:label "depicts" ;
    rdfs:range mdhn:Iconography .

mdhn:iconographyUsedIn a owl:ObjectProperty ;
    rdfs:comment "Indicates Resources that used this specified Iconography Subject" ;
    rdfs:domain mdhn:Iconography ;
    rdfs:label "iconography Used In" ;
    rdfs:range [
        a owl:Class ;
        owl:unionOf ( mdhn:ResourceCanvas mdhn:DigitalResource )
    ] ;      
    owl:inverseOf mdhn:depicts .

mdhn:charactersInvolved a owl:ObjectProperty ;
    rdfs:domain mdhn:NarrativeEpisode ;
    rdfs:label "characters Involve"@en ;
    rdfs:range mdhn:AgentialInfo . 

mdhn:hasPartIn a owl:ObjectProperty ; 
    rdfs:domain mdhn:AgentialInfo ;
    rdfs:range  mdhn:NarrativeEpisode ;
    rdfs:label  "persona appears in"@en ;
    owl:inverseOf mdhn:charactersInvolved .     

mdhn:hasParticipantInRole a owl:ObjectProperty, 
    owl:FunctionalProperty ;
    rdfs:domain mdhn:DigitalResource ;         
    rdfs:range  mdhn:AgentialInfo ;
    rdfs:label "has participant in some role"@en ;
    rdfs:comment "Generic relation between a DigitalResource/work and an agent playing any role in it."@en .    

mdhn:hasParticipantInRolePhotographer a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRolePhotographer" ;
    rdfs:range mdhn:AgentialInfo .  

mdhn:photographerOf a owl:ObjectProperty ;
    rdfs:comment "Associates a photographer to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "photographer of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRolePhotographer .     

mdhn:hasParticipantInRoleWriter a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRoleWriter" ;
    rdfs:range mdhn:AgentialInfo . 


mdhn:authorOf a owl:ObjectProperty ;
    rdfs:comment "Associates an author to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "author of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleWriter . 

mdhn:hasParticipantInRoleBinding a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRoleBinding" ;
    rdfs:range mdhn:AgentialInfo .  
mdhn:binderOf a owl:ObjectProperty ;
    rdfs:comment "Associates a binder to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "binder of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleBinding .          

mdhn:hasParticipantInRoleDirectorOfWorkShop a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRoleDirectorOfWorkShop" ;
    rdfs:range mdhn:AgentialInfo . 


mdhn:directorOfWorkShopOf a owl:ObjectProperty ;
    rdfs:comment "Associates a director of a workshop to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "director of work shop of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleDirectorOfWorkShop .        
     

mdhn:hasParticipantInRolePublisher a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRolePublisher" ;
    rdfs:range mdhn:AgentialInfo .

mdhn:publisherOf a owl:ObjectProperty ;
    rdfs:comment "Associates a publisher to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "publisher of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRolePublisher .              
           
mdhn:hasParticipantInRoleIllustrator a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRoleIllustrator" ;
    rdfs:range mdhn:AgentialInfo . 

mdhn:illustratorOf a owl:ObjectProperty ;
    rdfs:comment "Associates an illustrator to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "illustrator of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleIllustrator .     

mdhn:hasParticipantInRoleIlluminator a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRoleIlluminator" ;
    rdfs:range mdhn:AgentialInfo . 

mdhn:illuminatorOf a owl:ObjectProperty ;
    rdfs:comment "Associates an illuminator to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "illuminator of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleIlluminator .       

mdhn:hasParticipantInRoleScriber a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRoleScriber" ;
    rdfs:range mdhn:AgentialInfo . 

mdhn:scriberOf a owl:ObjectProperty ;
    rdfs:comment "Associates a scriber to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "scriber of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRoleScriber .      

