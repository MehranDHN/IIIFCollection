    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "hasParticipantInRolePainter" ;
    rdfs:range mdhn:AgentialInfo .

mdhn:painterOf a owl:ObjectProperty ;
    rdfs:comment "Associates a painter to its associated resources" ;
    rdfs:domain mdhn:DigitalResource ;
    rdfs:label "painter of" ;
    rdfs:range mdhn:AgentialInfo ;
    owl:inverseOf mdhn:hasParticipantInRolePainter .      

mdhn:hasParticipantInRoleFormerOwner a owl:ObjectProperty ;
    rdfs:subPropertyOf mdhn:hasParticipantInRole ;
    rdfs:comment "Links a Resource to participants";
    rdfs:domain mdhn:DigitalResource ;
