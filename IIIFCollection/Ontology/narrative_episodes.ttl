mdhn:Haft_Awrang a mdhn:NarrativeEpisode ;
    mdhn:aatConcept mdhn:aat300404746 ;
    mdhn:icWikiDataURL "https://www.wikidata.org/wiki/Q5638440" ;
    dcterms:created "c. 1010" ;
    rdfs:comment """The Haft Awrang, or Seven Thrones, is a collection of seven masnavi (long narrative poems) written by the Persian poet Nizami Ganjavi around 1010 CE. It is one of the most important works of Persian literature and tells various romantic and heroic stories."""@en ;
    rdfs:label "Haft Awrang"@en , "هفت اونگ"@fa . 
     

