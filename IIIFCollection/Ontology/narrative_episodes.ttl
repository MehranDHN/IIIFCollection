mdhn:Shahnameh a mdhn:NarrativeEpisode ;
    mdhn:aatConcept mdhn:aat300404209 ;
    mdhn:icWikiDataURL "https://www.wikidata.org/wiki/Q8279" ;
    dcterms:created "c. 1010" ;
    rdfs:comment """The Shahnameh, or Book of Kings, is an epic poem written by the Persian poet Ferdowsi around 1010 CE. It is one of the most important works of Persian literature and tells the mythical and historical past of Persia from the creation of the world until the Islamic conquest in the 7th century."""@en ;
    rdfs:label "Shahnameh"@en , "شاهنامه"@fa .



mdhn:Qisas_al_Anbiya a mdhn:NarrativeEpisode ;
    mdhn:aatConcept mdhn:aat300404209 ;
    mdhn:icWikiDataURL "https://www.wikidata.org/wiki/Q1087563" ;
    rdfs:comment """The Qiṣaṣ al-anbiyā (Arabic: قِصَص الْأَنـۢبِيَاء, lit. 'Stories of the Prophets') is any of various collections of stories about figures recognised as prophets and messengers in Islam, closely related to tafsīr (exegesis of the Qur'an)."""@en ;
    rdfs:label "Qisas al-Anbiya"@en , "قِصَص الْأَنـۢبِيَاء"@fa .    

mdhn:Khamsa_of_Nizami a mdhn:NarrativeEpisode ;
    mdhn:aatConcept mdhn:aat300404746 ;
    mdhn:icWikiDataURL "https://www.wikidata.org/wiki/Q3196058" ;
    dcterms:created "c. 1010" ;
    rdfs:comment """The Khamsa (Persian: خمسه, 'Quintet' or 'Quinary', from Arabic) or Panj Ganj (Persian: پنج گنج, 'Five Treasures') is the main and best known work of Nizami Ganjavi. """@en ;
    rdfs:label "Khamsa_of_Nizami"@en , "خمسه نظامی"@fa .   

