                                "linguisticElements": [
                                    {
                                        "elementType": "mdhn:Text_or_Verses",
                                        "elementLabel": "Textblock1 in 208r",
                                        "croppedImage": "https://iiif-cloud.princeton.edu/iiif/2/0e%2Fa6%2F9f%2F0ea69ff3cdaa4dd49042515e7e803d36%2Fintermediate_file/1946,2852,4392,966/full/0/default.jpg",
                                        "elementStyle": [
                                            "aat:300265532"
                                        ],
                                        "elementFAText": "بدانگه تو پیروز باشی مگر",
                                        "elementENText": "",
                                        "elementTextBlocks": [
                                            "بدانگه تو پیروز باشی مگر",
                                            "اگر یار باشدت پیروزگر",
                                            "نکرد ایچ رستم به رفتن شتاب",
                                            "بدان تا برآمد بلند آفتاب",
                                            "سراپای اولاد بر هم ببست",
                                            "به خم کمند آنگهی برنشست",
                                            "برآهیخت جنگی نهنگ از نیام",
                                            "بغرید چون رعد و برگفت نام",
                                            "میان سپاه اندر آمد چو گرد",
                                            "سران را سر از تن همی دور کرد"
                                        ],
                                        "elementLOUD": [
                                            "mdhn:Rostam",
                                            "mdhn:White_Div_7th_Course"
                                        ]
                                    },
                                    {
                                        "elementType": "mdhn:Text_or_Verses",
                                        "elementLabel": "Textblock2 in 208r",
                                        "croppedImage": "https://iiif-cloud.princeton.edu/iiif/2/0e%2Fa6%2F9f%2F0ea69ff3cdaa4dd49042515e7e803d36%2Fintermediate_file/1946,2852,4392,966/full/0/default.jpg",
                                        "elementStyle": [
                                            "aat:300265532"
                                        ],
                                        "elementFAText": "ناستاد کس پیش او در به جنگ",
                                        "elementENText": "",
                                        "elementTextBlocks": [
                                            "ناستاد کس پیش او در به جنگ",
                                            "نجستند با او یکی نام و ننگ",
                                            "رهش باز دادند و بگریختند",
                                            "به آورد با او نیاویختند",
                                            "وزان جایگه سوی دیو سپید",
                                            "بیامد به کردار تابنده شید",
                                            "به کردار دوزخ یکی غار دید",
                                            "تن دیو از تیرگی ناپدید",
                                            "زمانی همی بود در چنگ تیغ",
                                            "نبد جای دیدار و راه گریغ"
                                        ],
                                        "elementLOUD": [
                                            "mdhn:Rostam",
                                            "mdhn:White_Div_7th_Course"
                                        ]
                                    }
