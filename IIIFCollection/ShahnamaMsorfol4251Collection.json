                                        "elementTextBlocks": [
                                            "از ایشان فراوان تبه کرد نیز",
                                            "نبود از بدبخت ماننده چیز",
                                            "چو تاریک شد چشم کاووس شاه",
                                            "بد آمد ز کردار او بر سپاه",
                                            "همه گنج تاراج و لشکر اسیر",
                                            "جوان دولت و بخت برگشت پیر"
