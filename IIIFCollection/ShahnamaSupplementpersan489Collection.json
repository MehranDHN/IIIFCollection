                                        "elementStyle": [
                                            "aat:300195198"
                                        ],
                                        "elementFAText": "جمگ رستم با افراسياب بارآور",
                                        "elementENText": "Battle of Rostam and Afrasiab",
                                        "elementLOUD": [
                                            "mdhn:Rostam",
                                            "mdhn:Afrasiab"
                                        ]
                                    },
                                    {
                                        "elementType": "mdhn:Text_or_Verses",
                                        "elementLabel": "Textblock1 in 66r",
                                        "croppedImage": "https://images.lib.cam.ac.uk/iiif/MS-RAS-00239-00001-000-00087.jp2/1944,2349,3102,2099/full/0/default.jpg",
                                        "elementStyle": [
                                            "aat:300265532"
                                        ],
                                        "elementFAText": "من امروز بند کمرگاه اوی",
                                        "elementENText": "",
                                        "elementTextBlocks": [
                                            "من امروز بند کمرگاه اوی",
                                            "بگیرم کشانش بیارم بروی",
                                            "بدو گفت زال ای پسر گوش‌دار",
                                            "یک امروز با خویشتن هوش‌دار",
                                            "که آن ترک در جنگ نر اژدهاست",
                                            "در آهنگ و در کینه اَبر بلاست",
                                            "درفشش سیاهست و خفتان سیاه",
                                            "ز آهنش ساعد ز آهن کلاه",
                                            "همه روی آهن گرفته به زر",
                                            "نشانی سیه بسته بر خود بر",
                                            "ازو خویشتن را نگه‌دار سخت",
                                            "که مردی دلیرست و پیروز بخت",
                                            "بدو گفت رستم که ای پهلوان",
                                            "تو از من مدار ایچ رنجه روان",
                                            "جهان آفریننده یار منست",
                                            "دل و تیغ و بازو حصار منست",
                                            "برانگیخت آن رخش رویینه سم",
                                            "برآمد خروشیدن گاو دم"
                                        ],
                                        "elementLOUD": [
                                            "mdhn:Rostam",
                                            "mdhn:Afrasiab"
                                        ]
                                    },
                                    {
                                        "elementType": "mdhn:Text_or_Verses",
                                        "elementLabel": "Textblock2 in 66r",
                                        "croppedImage": "https://gallica.bnf.fr/iiif/ark:/12148/btv1b8422995t/f143/1261,3662,2506,1128/full/0/default.jpg",
                                        "elementStyle": [
                                            "aat:300265532"
                                        ],
                                        "elementFAText": "همی خواست بردنش پیش قباد",
                                        "elementENText": "",
                                        "elementTextBlocks": [
                                            "همی خواست بردنش پیش قباد",
                                            "دهد روز جنگ نخستینش داد",
                                            "ز هنگ سپهدار و چنگ سوار",
                                            "نیامد دوال کمر پایدار",
                                            "گسست و به خاک اندر آمد سرش",
                                            "سواران گرفتند گرد اندرش",
                                            "سپهبد چو از چنگ رستم بجست",
                                            "بخائید رستم همی پشت دست",
                                            "چرا گفت نگرفتمش زیرکش",
                                            "همی بر کمر ساختم بند خوش",
                                            "چو آوای زنگ آمد از پشت پیل",
                                            "خروشیدن کوس بر چند میل",
                                            "یکی مژده بردند نزدیک شاه",
                                            "که رستم بدرید قلب سپاه"
                                        ],
                                        "elementLOUD": [
                                            "mdhn:Rostam",
                                            "mdhn:Afrasiab"
                                        ]
                                    }
