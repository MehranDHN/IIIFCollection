    "metadata": [
        {
            "label": "Physical description",
            "value": "A machine readable hierarchical Digital Cultural Heritage Catalogue compatible with IIIF 2.0 Presentation API."
        },
        {
            "label": "Contributors",
            "value": "MehranDHN"
        },
        {
            "label": "Notes",
            "value": "IIIFDexir is a large-scale, nested IIIF Collection ecosystem built on the International Image Interoperability Framework (IIIF) Presentation API. It features a root collection with deeply hierarchical sub-collections, integrating IIIF resources (Manifests and Collections) from approximately 70 international GLAM institutions.<br/> Key technical aspects:"
        },
        {
            "label": "Structure",
            "value": "Tree-like nesting of Collections and Manifests in JSON-LD format, enabling recursive browsing in compliant viewers."
        },
        {
            "label": "Semantic Enrichment",
            "value": "Augmented with custom RDF ontology (Turtle format) defining classes (e.g., ResourceCollection, DigitalResource, Creator) and properties (e.g., hasCreator, hasTGNPlace), aligned with standards like Schema.org, Wikidata, AAT, and TGN."
        },
        {
            "label": "Folio and Content Decomposition",
            "value": "A core innovation in IIIFDexir is the granular decomposition of manuscript folios leveraging the IIIF Canvas concept (IIIF Presentation API). Each folio is modeled as a Canvas, which serves as a spatial container for its visual and textual content. This is further broken down into multiple content elements—discrete, semantically rich units that enable precise annotation, querying, and interoperability"
        },
        {
            "label": "Focus",
            "value": "Thematic aggregation of Persian/Iranian cultural materials, including \"Departed Collections\" that logically reunify physically dispersed assets."
        },
        {
            "label": "Queryable",
            "value": "The data is fully RDF compliant, enabling advanced queries using SPARQL across collections based on semantic annotations."
        },
        {
            "label": "Data Visualization",
            "value": "The observation of the whole collection structure and relationships is facilitated through any graph visualization can understand RDF."
        },
        {
            "label": "Source",
            "value": "Hosted at https://github.com/MehranDHN/IIIFCollection (root collection typically at paths like IIIFCollection/IIIF2Collection.json)."
        }
    ],
    "summary": {
        "en": [
            "A machine readable hierarchical Digital Cultural Heritage Catalogue compatible with IIIF 2.0 Presentation API."
        ]
    },
